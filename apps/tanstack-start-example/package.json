{
  "name": "@convex-verify/tanstack-start-example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,convex -c blue,green \"pnpm dev:web\" \"pnpm convex:dev\"",
    "dev:web": "sh -c 'if command -v portless >/dev/null 2>&1; then portless run vite dev; else echo \"portless not found; starting vite dev directly\"; vite dev; fi'",
    "dev:direct": "concurrently -k -n web,convex -c blue,green \"pnpm dev:web:direct\" \"pnpm convex:dev\"",
    "dev:web:direct": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "convex:dev": "pnpm exec convex dev",
    "convex:codegen": "pnpm exec convex codegen"
  },
  "dependencies": {
    "@tanstack/react-router": "1.168.10",
    "@tanstack/react-start": "1.167.16",
    "convex": "1.34.1",
    "convex-verify": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "portless": "^0.5.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  }
}
